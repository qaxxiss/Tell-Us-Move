
<%- include('partials/header') %>
<section class="section"><div class="container"><h2>Contact Us</h2><p class="lead">Questions? Reach our support team.</p><div class="form-card"><form action="/contact" method="post"><input name="name" placeholder="Your name" required><input name="email" type="email" placeholder="Your email" required><textarea name="message" placeholder="Message" required></textarea><div style="text-align:center;margin-top:12px"><button class="btn btn-primary" type="submit">Send Message</button></div></form><% if (typeof success !== 'undefined' && success) { %><p style="color:green;text-align:center">Message sent.</p><% } %></div></div></section><%- include('partials/footer') %>
