
<%- include('partials/header') %>
<section class="section"><div class="container"><h2>Track Shipment</h2><p class="lead">Enter your booking ID to check status. Note: Only confirmed bookings are trackable.</p><div class="form-card"><form action="/track" method="post"><input name="bookingId" placeholder="Booking ID" required><div style="text-align:center;margin-top:12px"><button class="btn btn-primary" type="submit">Track</button></div></form></div><% if (typeof result !== 'undefined') { if (result) { %><div class="card"><p><strong>Status:</strong> <%= result.status %></p><p><strong>Route:</strong> <%= result.pickup %> → <%= result.dropoff %></p></div><% } else { %><p class="lead">No confirmed booking found with that ID.</p><% } } %></div></section><%- include('partials/footer') %>
