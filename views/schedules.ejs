
<%- include('partials/header') %>
<section class="section"><div class="container"><h2>Schedules</h2><p class="lead">Upcoming confirmed shipments (contact details are private).</p><% if (schedules.length===0){ %><p>No confirmed schedules yet.</p><% } %><% schedules.forEach(function(s){ %><div class="card"><strong><%= s.name %></strong> — <%= s.pickup %> → <%= s.dropoff %> — <%= s.date %> — <em><%= s.status %></em></div><% }) %></div></section><%- include('partials/footer') %>
