
<%- include('partials/header') %>
<section class="section"><div class="container"><h2>Admin Dashboard</h2><div style="text-align:right"><a class="btn btn-outline" href="/admin-logout">Logout</a></div><h3>Pending Requests</h3><% if (bookings.length===0){ %><p class="lead">No pending requests.</p><% } %><% bookings.forEach(function(b){ if(b.status==='pending'){ %><div class="card"><strong><%= b.name %></strong> — <%= b.pickup %> → <%= b.dropoff %> — <%= b.date %><div>Email: <%= b.email %></div><div>Phone: <%= b.phone %></div><div style="margin-top:8px"><form style="display:inline" action="/admin/confirm/<%= b.id %>" method="post"><button class="btn" type="submit">Confirm</button></form> <form style="display:inline" action="/admin/cancel/<%= b.id %>" method="post"><button class="btn btn-outline" type="submit">Cancel</button></form></div></div><% } }) %></div></section><%- include('partials/footer') %>
