
<%- include('partials/header') %>
<section class="section"><div class="container"><h2>Book a Truck</h2><p class="lead">Complete the form to send a booking request. Admin will confirm and schedule.</p><div class="form-card"><form action="/book" method="post"><input name="name" placeholder="Full name" required><input name="email" type="email" placeholder="Email" required><input name="phone" placeholder="Phone number" required><input name="pickup" placeholder="Pickup location" required><input name="dropoff" placeholder="Drop location" required><select name="truckType"><option>Small</option><option>Medium</option><option>Heavy</option></select><input name="date" type="date" required><div style="text-align:center;margin-top:12px"><button class="btn btn-primary" type="submit">Send Request</button></div></form></div></div></section><%- include('partials/footer') %>
